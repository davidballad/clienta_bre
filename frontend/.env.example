VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Hosted UI domain (without https://) — required for Google Sign-In
# e.g. clienta-auth.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
# Optional: explicit app base URL for OAuth redirect_uri (defaults to window.location.origin)
VITE_APP_URL=https://br.clientaai.com
